generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model GuildConfig {
  guildId         String   @id
  rconHost        String?
  rconPort        Int?
  rconPasswordEnc String?
  adminRoleId     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
